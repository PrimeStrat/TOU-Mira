  <string name="TouRoleSpectatorIntroBlurb">Mira el caos desde lejos</string>
  <string name="TouRoleSpectatorTabDescription">¡Nunca participes, mira como se desarrolla el caos en el juego!</string>
  <string name="TouRoleSpectatorWikiDescription">No participas en el juego ni interactúas con los jugadores. Solo puedes observar.</string>
  <string name="TouRoleAltruist">Altruista</string>
  <string name="TouRoleAltruistIntroBlurb">Revivir Tripulantes Muertos</string>
  <string name="TouRoleAltruistTabDescription">Reviva a los compañeros de tripulación muertos en grupos, al \%nl\% costo de alertar a los asesinos y eliminar los usos de la reunión.</string>
  <string name="TouRoleAltruistWikiDescription">El Altruista es un rol de Tripulante Protector que puede revivir a jugadores muertos en grupos. Sin embargo, su ubicación y la de los jugadores revividos se revelarán a todos los impostores.</string>
  <string name="TouRoleAltruistRevive">Revivir</string>
  <string name="TouRoleAltruistReviving">Reviviendo</string>
  <string name="TouRoleAltruistReviveWikiDescription">Revive un grupo de cadáveres cerca de ti. Quedarás congelado durante la resurrección y no podrás moverte hasta que se complete. Los impostores también tendrán una flecha apuntando hacia ti durante la resurrección, así que ten cuidado.</string>
  <string name="TouOptionAltruistReviveDuration">Duración de revivir</string>
  <string name="TouOptionAltruistReviveRange">Rango de revivir</string>
  <string name="TouOptionAltruistMaxRevives">Usos de revivir</string>
  <string name="TouOptionAltruistHideAtBeginningOfRevive">Ocultar cuerpos al comienzo de la resurrección</string>
  <string name="TouRoleAurial">Perceptor</string>
  <string name="TouRoleAurialIntroBlurb">Siente las Perturbaciones en tu aura.</string>
  <string name="TouRoleAurialTabDescription">Sentirás cualquier habilidad utilizada dentro de tu aura</string>
  <string name="TouRoleAurialWikiDescription">El Perceptor es un rol de Tripulante Investigador que recibirá una alerta cada vez que un jugador cercano use una de sus habilidades.</string>
  <string name="TouOptionAurialAuraInnerRadius">Gama de colores en el Rango</string>
  <string name="TouOptionAurialAuraOuterRadius">Rango máximo de irradiación</string>
  <string name="TouOptionAurialSenseDuration">Duración del sentido</string>
  <string name="TouRoleCleric">Clérigo</string>
  <string name="TouRoleClericIntroBlurb">Salva los tripulantes</string>
  <string name="TouRoleClericTabDescription">Limpia los efectos negativos de los compañeros de tripulación y \%nl\% lanza barreras para detener cualquier interacción por completo</string>
  <string name="TouRoleClericWikiDescription">El Clérigo es un Tripulante Protector que puede proteger a sus compañeros de tripulación negando sus efectos negativos, así como colocando barreras sobre ellos para evitar interacciones.</string>
  <string name="TouRoleClericBarrier">Barrera</string>
  <string name="TouRoleClericBarrierWikiDescription">Evita que un compañero de tripulación sea interactuado. El escudo durará \%BarrierCooldown\% segundos.</string>
  <string name="TouRoleClericCleanse">Limpiar</string>
  <string name="TouRoleClericCleanseWikiDescription">Elimina todos los efectos negativos de un jugador (Empapar, Hackear, Infectar, Chantajear, Cegar, Destello e Hipnosis)</string>
  <string name="TouRoleClericMessageTitle">Comentarios del clérigo:</string>
  <string name="TouRoleClericCleansedEffects">Efectos limpiados en \%player\%:</string>
  <string name="TouRoleClericCleansedNoEffects">No se encontraron efectos negativos en \%player\%.</string>
  <string name="TouOptionClericBarrierCooldown">Tiempo de espera de barrera</string>
  <string name="TouOptionClericBarrierDuration">Duración de la barrera</string>
  <string name="TouOptionClericCleanseCooldown">Tiempo de espera de limpieza</string>
  <string name="TouOptionClericAttackNotif">El clérigo recibe una notificación de ataque</string>
  <string name="TouRoleDeputy">Diputado</string>
  <string name="TouRoleDeputyIntroBlurb">Acampar tripulantes para atrapar a su Asesino</string>
  <string name="TouRoleDeputyTabDescription">Acampa tripulantes, después dispara a su asesino en la reunión!</string>
  <string name="TouRoleDeputyWikiDescription">El Diputado es un Tripulante asesino que puede acampar a otros jugadores. Si un jugador acampado muere, el Diputado es notificado de su muerte. En la siguiente reunión, el Diputado puede intentar disparar al asesino del jugador acampado. Si tiene éxito, el asesino muere; si no, no ocurre nada.</string>
  <string name="TouRoleDeputyCamp">Acampar</string>
  <string name="TouRoleDeputyCampWikiDescription">Acampa a un jugador para recibir una alerta si muere. Tras su muerte, puedes intentar dispararle a su asesino. Si tu disparo es acertado, el asesino muere; si no, no ocurrirá nada.</string>
  <string name="TouRoleDeputyMissedShot">¡Fallaste! O no son los asesinos o son invencibles.</string>
  <string name="TouRoleForensic">Detective</string>
  <string name="TouRoleForensicIntroBlurb">Inspecciona las escenas del crimen para atrapar al asesino</string>
  <string name="TouRoleForensicTabDescription">Inspecciona escenas de crimen, luego examina jugadores para ver si estaban en la escena.</string>
  <string name="TouRoleForensicWikiDescription">El Detective puede inspeccionar una escena de crimen y examinar jugadores lara ver si estaban en la escena del crimen, dando una luz roja si se da el caso.</string>
  <string name="TouRoleForensicInspect">Inspeccionar</string>
  <string name="TouRoleForensicInspectWikiDescription">Escenas del crimen aparecerán con todos los cuerpos muertos. Inspecciona la escena del crimen y luego examina jugadores para descubrir pistas. Durante la siguiente reunión, recivirás un informe revelando el rol del asesino.</string>
  <string name="TouRoleForensicExamine">Examinar</string>
  <string name="TouRoleForensicExamineWikiDescription">Examina jugadores tras examinar una escena del crimen. Serás dicho si el jugador estaba en la escena del crimen.</string>
  <string name="TouOptionForensicExamineCooldown">Tiempo de espera para examinar</string>
  <string name="TouOptionForensicReportOn">Mostrar Informes de Detective</string>
  <string name="TouOptionForensicRoleDuration">Tiempo Durante el que el Detective Tendrá el Rol</string>
  <string name="TouOptionForensicFactionDuration">Tiempo Durante el cual Detective Tendrá Facción</string>
  <string name="TouRoleForensicAtScene">\%player\% estaba en la escena de la muerte de \%deadPlayer\%\%nl\%Es posible que sea el asesino o un testigo.</string>
  <string name="TouRoleForensicNotAtScene">\%player\%no estaba en la escena del crimen.</string>
  <string name="TouRoleEngineer">Ingeniero</string>
  <string name="TouRoleEngineerIntroBlurb">Mantén Sistemas Importantes en la Nave</string>
  <string name="TouRoleEngineerTabDescription">Usa las ventilaciones y arregla sabotajes remotamente</string>
  <string name="TouRoleEngineerWikiDescription">El Ingeniero es un Tripulante de Apoyo que puede usar las ventilaciones y arreglar sabotajes remotamente.</string>
  <string name="TouRoleEngineerFix">Arreglar</string>
  <string name="TouRoleEngineerFixing">Arreglando</string>
  <string name="TouRoleEngineerFixWikiDescription">No importa donde estés en el mapa, puedes utilizar tu botón arreglar para arreglar inmediatamente el sabotaje activo. Puedes hacer esto \%engiMaxFixes\% veces por partida.</string>
  <string name="TouOptionEngineerMaxVents">Usos de Ventilación por Partida</string>
  <string name="TouOptionEngineerVentDuration">Duración de Ventilación</string>
  <string name="TouOptionEngineerMaxFixes">Usos de Arreglar Por Partida</string>
  <string name="TouOptionEngineerFixDelay">Retraso de Arreglar</string>
  <string name="TouRoleHaunter">Perseguidor</string>
  <string name="TouRoleHaunterIntroBlurb">¡Revela a Los Impostores tras tu muerte!</string>
  <string name="TouRoleHaunterTabDescription">¡Completa todas tus tareas sin ser atrapado para revelar a los impostores!</string>
  <string name="TouRoleHaunterWikiDescription">El Perseguidor es un Tripulante Fantasma que puede hacer tareas. Aparecerán como un jugador transparente. Si acaban todas sus tareas, todos los jugadores vivos verán quienes son los Impostores. Sin embargo, si un Impostor les hace click primero, se convertirán en un fantasma normal. Los Impostores reciven una alerta antes de que y cuando el Perseguidor acabe sus tareas.</string>
  <string name="TouOptionHaunterNumTasksLeftBeforeClickable">Tareas Restantes Antes de ser Clickeable</string>
  <string name="TouOptionHaunterNumTasksLeftBeforeAlerted">Tareas Restantes Antes de ser Alertado</string>
  <string name="TouOptionHaunterRevealNeutralRoles">Revelar Roles Neutrales</string>
  <string name="TouOptionHaunterCanBeClickedBy">Puede Ser Clickeado Por</string>
  <string name="TouRoleHaunterSelfAlertFeedback">¡Has alertado a los Asesinos!</string>
  <string name="ClientTabGameplay">Juego</string>
  <string name="ShowVanillaWikiEntries">Mostrar Entradas Base de la Wiki</string>
  <string name="PlayerHasNoModifiers">No modificadores</string>
  <string name="SpecialNeutral">Neutral Especial</string>
  <string name="TouRoleDeputyCampNotif">Espera para la muerte de \%player\% para poder disparar a su asesino en la discusión.</string>
  <string name="TouRoleDeputyMessageTitle">Comentarios del Diputado</string>
  <string name="TouRoleForensicInspectNotif">Has inspeccionados la escena del crimen de \%player\%. El asesino, o cualquiera que haya pisado en la escena del crimen, parpadeará rojo cuando sea examinado.</string>
  <string name="TouOptionEngineerVentCooldown">Tiempo de Espera de Ventilaciones</string>
  <string name="TouRoleHaunterImpAlertFeedback">Un Perseguidor está libre, ¡Atrápalo antes de que pueda revelarte!</string>
  <string name="TouRoleHunter">Cazador</string>
  <string name="TouRoleHunterIntroBlurb">Acecha El \%color=#FF0000FF\%Impostor\%/color\%</string>
  <string name="TouRoleHunterTabDescription">Acecha jugadores para ser alertado cuando usan una habilidad. \%nl\%Una vez usen una habilidad, podrás matarlos.</string>
  <string name="TouRoleHunterCaughtPlayersText">Jugadores Atrapados:</string>
  <string name="TouRoleHunterWikiDescription">El Cazador es un rol de Tripulante Asesino que puede acechar jugadores durante la ronda. Si un jugador acechado usa una habilidad, podrán ser matados por el Cazador en cualquier punto de la partida, incluso Tripulantes.</string>
  <string name="TouRoleHunterStalk">Acechar</string>
  <string name="TouRoleHunterStalking">Acechando</string>
  <string name="TouRoleHunterStalkWikiDescription">Elige un objetivo para acechar. Puedes acechar \%hunterMaxStalkUsages\% jugadores. Si usan cualquier habilidad mientras son acechados, serán añadidos a tu lista de objetivos, y podrán ser matados.</string>
  <string name="TouRoleHunterStalkNotif">Si \%player\% usa una habilidad, serás capaz de matarlos en cualquier momento de la ronda.</string>
  <string name="TouOptionHunterKillCooldown">Tiempo de Espera tras Matar del Cazador</string>
  <string name="TouOptionHunterStalkCooldown">Tiempo de Espera de Acechamiento del Cazador</string>
